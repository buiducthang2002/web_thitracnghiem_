# Cấu hình Firebase — sao chép file này thành ".env" rồi điền giá trị thật
# Lấy tại: Firebase Console → ⚙️ Project Settings → Your apps → SDK setup and configuration
#
# ⚠️ File .env KHÔNG được commit lên GitHub (đã có trong .gitignore)

VITE_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=ten-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ten-project
VITE_FIREBASE_STORAGE_BUCKET=ten-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
